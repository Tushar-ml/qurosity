---
import type { CollectionEntry } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getPostUrl } from "@/utils/getPostPaths";
import { toTransitionName } from "@/utils/toTransitionName";
import { slugifyStr } from "@/utils/slugify";
import Datetime from "./Datetime.astro";
import config from "@/config";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, series, seriesPart, ...props } = data;
const locale = Astro.currentLocale ?? config.site.lang;
---

<li class="my-6">
  <a
    href={getPostUrl(id, filePath, Astro.currentLocale)}
    class:list={[
      "text-accent inline-block text-lg font-medium",
      "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading transition:name={toTransitionName(title)}>
      {title}
    </Heading>
  </a>
  <div class="mt-1.5 mb-2 flex flex-wrap items-center gap-x-3 gap-y-1">
    <Datetime {...props} />
    {
      series && (
        <a
          href={getRelativeLocaleUrl(locale, `series/${slugifyStr(series)}`)}
          class="text-muted-foreground hover:text-accent border-border flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs font-medium transition-colors"
        >
          <span class="opacity-60">§</span>
          {series}{seriesPart ? ` · Part ${seriesPart}` : ""}
        </a>
      )
    }
  </div>
  <p>{description}</p>
</li>
